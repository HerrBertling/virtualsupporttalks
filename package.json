    "@react-router/fs-routes": "^7.0.0",
    "@tailwindcss/typography": "^0.5.13",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cf-content-types-generator": "^2.16.1",
    "contentful-management": "^11.27.6",
    "dotenv": "^17.2.3",
    "postcss": "^8.4.39",
    "typescript": "^5.1.6",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^4.2.1",
    "vitest": "^4.0.18"
